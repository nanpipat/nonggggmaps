# PawMap environment variables

# === Supabase (optional — app works with mock data if unset) ===
# Sign up at https://supabase.com and create a project, then paste here:
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# === Map (Leaflet uses OpenStreetMap by default — no key needed) ===
# Optionally use MapTiler / Stadia / Mapbox:
NEXT_PUBLIC_MAP_TILE_URL=
NEXT_PUBLIC_MAP_ATTRIBUTION=

# === Default map center (Bangkok) ===
NEXT_PUBLIC_DEFAULT_LAT=13.7563
NEXT_PUBLIC_DEFAULT_LNG=100.5018
